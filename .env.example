# Copy this file to .env.local (Next.js does NOT read .env.example)
# cp .env.example .env.local

ADMIN_KEYWORD=your-secret-keyword
ADMIN_USERNAME=site-owner
ADMIN_PASSWORD=your-secure-password
# Use quotes if the secret contains # or $ characters:
SESSION_SECRET="your-long-random-secret-at-least-32-chars"

# Optional: persist dashboard edits on Vercel or Netlify (free Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
