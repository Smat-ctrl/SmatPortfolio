# Copy this file to .env.local (Next.js does NOT read .env.example)
# cp .env.example .env.local

ADMIN_KEYWORD=your-secret-keyword
ADMIN_USERNAME=site-owner
ADMIN_PASSWORD=your-secure-password
# Use quotes if the secret contains # or $ characters:
SESSION_SECRET="your-long-random-secret-at-least-32-chars"

# Optional fallback for non-Netlify deployments.
# Netlify uses Netlify Blobs automatically for dashboard edits and resume uploads.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
